<Window x:Class="MediWait.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prevodniky="clr-namespace:MediWait.Wpf.Prevodniky"
        mc:Ignorable="d"
        Title="MediWait - Osobní správce návštěv" Height="760" Width="1200" MinHeight="640" MinWidth="980">
    <Window.Resources>
        <prevodniky:StavTerminuNaStetecPrevodnik x:Key="StavTerminuNaStetecPrevodnik" />
    </Window.Resources>

    <Grid Background="{Binding PozadiAplikace}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource StetecPrimarni}" CornerRadius="0,0,18,18" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="MediWait" FontSize="34" Foreground="White" FontWeight="Bold" />
                    <TextBlock Text="Digitální čekárenský přehled návštěv u lékaře" Foreground="White" Opacity="0.9" />
                    <TextBlock Text="{Binding StavSenzoru}" Foreground="White" Opacity="0.85" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" VerticalAlignment="Center">
                    <Button Content="Přepnout motiv" Command="{Binding PrepnoutMotivPrikaz}" />
                    <Button Content="Nouzové kontakty" Command="{Binding OtevritNouzoveKontaktyPrikaz}" />
                    <Button Content="Simulovat zatřesení" Command="{Binding SimulovatZatraseniPrikaz}" />
                    <Button Content="Přepnout senzor" Command="{Binding PrepnoutSenzorPrikaz}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="16" Padding="18">
                <StackPanel>
                    <TextBlock Text="Nová nebo upravená návštěva" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Termín" />
                    <DatePicker SelectedDate="{Binding DatumNavstevy, Mode=TwoWay}" />
                    <TextBlock Text="Čas" Margin="0,8,0,0" />
                    <TextBox Text="{Binding CasNavstevy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Lékař" Margin="0,8,0,0" />
                    <TextBox Text="{Binding JmenoLekare, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Lék" Margin="0,8,0,0" />
                    <TextBox Text="{Binding NazevLeku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Poznámka" Margin="0,8,0,0" />
                    <TextBox Text="{Binding Poznamka, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="90" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Uložit" Command="{Binding UlozitPrikaz}" />
                        <Button Content="Vyčistit" Command="{Binding VymazatFormularPrikaz}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="18">
                <TabControl SelectedIndex="{Binding VybranaKarta}">
                    <TabItem Header="Dnešní přehled">
                        <ListView ItemsSource="{Binding DnesniPolozky}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#FFE4E4E4" BorderThickness="1" CornerRadius="10" Margin="0,0,0,8" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Termin, StringFormat={}{0:dd.MM.yyyy HH:mm}}"
                                                           Foreground="{Binding Converter={StaticResource StavTerminuNaStetecPrevodnik}}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding Lekar}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Lek}" />
                                                <TextBlock Text="{Binding Poznamka}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Button Content="Upravit" Command="{Binding DataContext.UpravitPrikaz, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <Button Content="Hotovo" Command="{Binding DataContext.OznacitJakoHotovoPrikaz, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                                <Button Content="Smazat" Command="{Binding DataContext.SmazatPrikaz, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </TabItem>

                    <TabItem Header="Kalendář">
                        <ListView ItemsSource="{Binding BudouciPolozky}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Termin, StringFormat={}{0:dddd dd.MM.yyyy HH:mm}}"
                                                   Foreground="{Binding Converter={StaticResource StavTerminuNaStetecPrevodnik}}"
                                                   FontWeight="Bold" />
                                        <TextBlock Text="{Binding Lekar}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </TabItem>

                    <TabItem Header="Historie">
                        <ListView ItemsSource="{Binding HistorickePolozky}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Termin, StringFormat={}{0:dd.MM.yyyy HH:mm}}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding Lekar}" />
                                        <TextBlock Text="{Binding Poznamka}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="16,0,16,16" Padding="12" CornerRadius="12" Background="#FFF9F2D6" Visibility="{Binding NouzoveKontaktyViditelnost}">
            <StackPanel>
                <TextBlock Text="Nouzové kontakty" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="Záchranná služba: 155" />
                <TextBlock Text="Rodinný kontakt: +420 777 123 456" />
                <TextBlock Text="{Binding NouzovaZprava}" FontWeight="SemiBold" Foreground="DarkRed" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
