<Application x:Class="MediWait.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="BarvaPrimarni">#FF246B86</Color>
        <Color x:Key="BarvaSekundarni">#FF62B6CB</Color>
        <SolidColorBrush x:Key="StetecPrimarni" Color="{StaticResource BarvaPrimarni}" />
        <SolidColorBrush x:Key="StetecSekundarni" Color="{StaticResource BarvaSekundarni}" />
        <Style TargetType="Button">
            <Setter Property="Margin" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource StetecPrimarni}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="14" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="14,8" />
        </Style>
    </Application.Resources>
</Application>
